# MedTour AI environment template
# Copy to `.env` for local development. Do not commit real secrets.

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_NAME=medtour_ai_planner
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:8000
PUBLIC_WEB_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:8000,http://localhost:5173,http://127.0.0.1:8000,http://127.0.0.1:5173
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=SGD
DEFAULT_TIMEZONE=Asia/Singapore

# Default planner backend:
# - local: deterministic local planner, no OpenAI call
# - adk: Google ADK multi-agent planner using OpenAI via LiteLLM
DEFAULT_PLANNER_BACKEND=local
REPORT_GENERATION_MODE=sync
MAX_CITY_OPTIONS=4

# -----------------------------------------------------------------------------
# Security and sessions
# -----------------------------------------------------------------------------
# Generate strong random values for real deployments.
SESSION_SECRET=replace-with-32-byte-random-string
JWT_SECRET=replace-with-32-byte-random-string
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost
ANONYMOUS_SESSION_TTL_DAYS=7
REPORT_RETENTION_DAYS=30
RATE_LIMIT_PER_MINUTE=60

# Optional auth providers. Leave blank for local-only anonymous sessions.
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
IDENTITY_PLATFORM_AUDIENCE=

# -----------------------------------------------------------------------------
# OpenAI / LiteLLM / ADK
# -----------------------------------------------------------------------------
# Required only when DEFAULT_PLANNER_BACKEND=adk or request planner_backend="adk".
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
LLM_MODEL=openai/gpt-4o-mini
PLANNER_MODEL=openai/gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT_SECONDS=60
MODEL_MAX_RETRIES=2
MODEL_JSON_MODE=true
MODEL_LOG_PROMPTS=false

# Google ADK local/dev settings.
ADK_APP_NAME=medtour_ai_planner
ADK_SESSION_BACKEND=in_memory
ADK_TRACE_ENABLED=true

# -----------------------------------------------------------------------------
# Google Cloud
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-southeast1
GOOGLE_CLOUD_LOCATION=asia-southeast1
SERVICE_ACCOUNT_EMAIL=

# Cloud Run service names used by deployment scripts and logs.
CLOUD_RUN_API_SERVICE=medtour-api
CLOUD_RUN_ORCHESTRATOR_SERVICE=medtour-orchestrator
CLOUD_RUN_AGENT_WORKER_SERVICE=medtour-agent-worker
CLOUD_RUN_INGESTION_JOB=medtour-ingestion-job
CLOUD_RUN_PDF_EXPORTER_SERVICE=medtour-pdf-exporter

# Pub/Sub and Cloud Tasks names for production async execution.
PUBSUB_AGENT_TASK_TOPIC=medtour-agent-tasks
PUBSUB_AGENT_RESULT_TOPIC=medtour-agent-results
CLOUD_TASKS_QUEUE_REPORTS=medtour-report-generation
CLOUD_TASKS_QUEUE_TIMELINES=medtour-timeline-regeneration
CLOUD_TASKS_LOCATION=asia-southeast1

# Secret Manager secret ids. Keep values blank locally unless you load secrets.
SECRET_OPENAI_API_KEY=medtour-openai-api-key
SECRET_DATABASE_URL=medtour-database-url
SECRET_REDIS_URL=medtour-redis-url
SECRET_JWT_SECRET=medtour-jwt-secret

# -----------------------------------------------------------------------------
# Database, cache, and object storage
# -----------------------------------------------------------------------------
# Local development can use the in-memory store. Production should set DATABASE_URL.
STORE_BACKEND=memory
DATABASE_URL=
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_SSL_MODE=require

# PostgreSQL/pgvector knowledge base.
VECTOR_DATABASE_URL=
VECTOR_TABLE_NAME=knowledge_chunks
VECTOR_DIMENSIONS=1536
VECTOR_TOP_K=8
RAG_MIN_CONFIDENCE=0.55

# Redis / Memorystore for report status, locks, and cached estimates.
REDIS_URL=
REDIS_REPORT_STATUS_TTL_SECONDS=3600
REDIS_CACHE_TTL_SECONDS=3600

# Cloud Storage / local export storage.
STORAGE_BACKEND=local
GCS_EXPORT_BUCKET=
GCS_KNOWLEDGE_BUCKET=
LOCAL_EXPORT_DIR=/tmp/medtour_ai_exports
SIGNED_URL_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# External data providers
# -----------------------------------------------------------------------------
# Leave blank for deterministic local estimates.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
FLIGHT_PROVIDER=local
FLIGHT_API_BASE_URL=
FLIGHT_API_KEY=
HOTEL_PROVIDER=local
HOTEL_API_BASE_URL=
HOTEL_API_KEY=
FX_PROVIDER=local
FX_API_BASE_URL=
FX_API_KEY=
DEFAULT_FX_BASE_CURRENCY=SGD

# Visa and policy source configuration.
VISA_POLICY_PROVIDER=curated
VISA_POLICY_REFRESH_HOURS=24
CHINA_VISA_APPLICATION_URL=https://www.visaforchina.cn/
CHINA_NIA_URL=https://en.nia.gov.cn/

# Payment readiness links.
ALIPAY_INTERNATIONAL_GUIDE_URL=https://render.alipay.com/p/yuyan/180020010001196791/index.html
ALIPAY_PLUS_URL=https://www.alipayplus.com/

# -----------------------------------------------------------------------------
# Knowledge ingestion
# -----------------------------------------------------------------------------
INGESTION_ENABLED=false
INGESTION_SCHEDULE_CRON=0 3 * * *
KNOWLEDGE_SOURCE_CONFIG_PATH=knowledge_sources.yaml
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=150
KNOWLEDGE_MAX_DOCUMENTS_PER_RUN=100
KNOWLEDGE_REQUIRE_SOURCE_URL=true

# -----------------------------------------------------------------------------
# Advisor and CRM handoff
# -----------------------------------------------------------------------------
ADVISOR_HANDOFF_ENABLED=true
ADVISOR_NOTIFICATION_EMAIL=
CRM_PROVIDER=none
CRM_API_BASE_URL=
CRM_API_KEY=
CRM_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# PDF/export
# -----------------------------------------------------------------------------
PDF_EXPORT_ENABLED=true
PDF_RENDER_TIMEOUT_SECONDS=30
PDF_BRAND_NAME=MedTour AI

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_STRUCTURED_LOGGING=true
ENABLE_CLOUD_TRACE=false
ENABLE_ERROR_REPORTING=false
ENABLE_METRICS=true
TRACE_SAMPLE_RATE=0.1
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Compliance and safety
# -----------------------------------------------------------------------------
REDACT_SENSITIVE_LOGS=true
ALLOW_MODEL_MEDICAL_FREE_TEXT=false
SEND_STRONG_IDENTIFIERS_TO_MODEL=false
REQUIRE_ADVISOR_CONSENT=true
ENABLE_MEDICAL_DISCLAIMERS=true
ENABLE_BOOKING_WARNINGS=true

# -----------------------------------------------------------------------------
# Local development helpers
# -----------------------------------------------------------------------------
MOCK_EXTERNAL_APIS=true
MOCK_TODAY=
SEED_SAMPLE_DATA=false
