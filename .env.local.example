# Minimal local development config
# Copy to `.env` when running the deterministic local planner.

APP_NAME=medtour_ai_planner
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:8000,http://localhost:5173,http://127.0.0.1:8000

DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=SGD
DEFAULT_TIMEZONE=Asia/Singapore
DEFAULT_PLANNER_BACKEND=local
REPORT_GENERATION_MODE=sync
MAX_CITY_OPTIONS=4

STORE_BACKEND=memory
STORAGE_BACKEND=local
LOCAL_EXPORT_DIR=/tmp/medtour_ai_exports
MOCK_EXTERNAL_APIS=true

SESSION_SECRET=local-dev-session-secret
JWT_SECRET=local-dev-jwt-secret
COOKIE_SECURE=false

LOG_LEVEL=INFO
LOG_FORMAT=pretty
REDACT_SENSITIVE_LOGS=true
ENABLE_MEDICAL_DISCLAIMERS=true
ENABLE_BOOKING_WARNINGS=true
